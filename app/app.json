{
  "expo": {
    "name": "Glink",
    "slug": "glink",
    "version": "0.1.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff5f9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.glink.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSMicrophoneUsageDescription": "Glink записывает голосовые сообщения",
        "NSCameraUsageDescription": "Glink записывает видео-кружки",
        "NSPhotoLibraryUsageDescription": "Glink отправляет фото и файлы в чат"
      }
    },
    "android": {
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#fff5f9"
      },
      "package": "com.glink.app",
      "permissions": [
        "INTERNET",
        "RECORD_AUDIO",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "serverUrl": "https://31.128.38.147:3920",
      "eas": {
        "projectId": "6f9b01a6-a682-4ec8-8ea1-e08f7c481412"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "./plugins/withGlinkAndroidNetwork.js"
    ]
  }
}
